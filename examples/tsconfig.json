{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "checkJs": false,
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "outDir": "dist"
    },
    "include": [
        "src/**/*.mjs",
        "src/**/*.js",
        "src/**/*.jsx",
        "src/**/*.d.ts",
        "iframe/**/*.mjs",
        "iframe/**/*.js",
        "templates/**/*.mjs",
        "utils/**/*.mjs",
        "build.mjs",
        "vite.config.mjs"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "cache",
        "assets/wasm"
    ]
}
