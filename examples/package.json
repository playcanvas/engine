{
  "name": "examples-browser",
  "version": "0.0.0",
  "description": "Examples browser for the PlayCanvas Engine",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production node build.mjs",
    "build:metadata": "node build.mjs --metadata",
    "build:thumbnails": "node build.mjs --thumbnails",
    "clean": "node build.mjs --clean",
    "develop": "npm run -s build:metadata && cross-env NODE_ENV=development vite",
    "develop:no-hmr": "npm run -s build:metadata && cross-env NODE_ENV=development vite --no-hmr",
    "lint": "eslint .",
    "serve": "vite preview",
    "type:check": "npm run -s type:check:app && npm run -s type:check:examples",
    "type:check:app": "npm run -s build:metadata && tsc -p tsconfig.app.json --pretty false",
    "type:check:examples": "tsc -p tsconfig.examples.json --pretty false"
  },
  "devDependencies": {
    "@babel/standalone": "7.29.2",
    "@monaco-editor/react": "4.7.0",
    "@playcanvas/eslint-config": "2.1.0",
    "@playcanvas/observer": "1.7.1",
    "@playcanvas/pcui": "5.8.0",
    "@tweenjs/tween.js": "25.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "esbuild": "0.27.4",
    "examples": "file:./iframe",
    "fflate": "0.8.2",
    "fs-extra": "11.3.4",
    "monaco-editor": "0.55.1",
    "playcanvas": "file:..",
    "prop-types": "15.8.1",
    "puppeteer": "24.42.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.14.2",
    "sharp": "0.34.5",
    "typescript": "5.9.3",
    "vite": "6.4.2"
  },
  "author": "PlayCanvas <support@playcanvas.com>",
  "license": "MIT"
}
