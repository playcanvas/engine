{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://playcanvas.com/schemas/runtime-tools/v1/snapshot.schema.json",
    "title": "PlayCanvas runtime-tools protocol v1 snapshot",
    "type": "object",
    "required": ["version", "engine", "app", "scene", "assets", "render", "diagnostics", "perf"],
    "properties": {
        "version": { "const": 1 },
        "engine": {
            "type": "object",
            "required": ["version", "revision", "buildVariant"],
            "properties": {
                "version": { "type": "string" },
                "revision": { "type": "string" },
                "buildVariant": { "enum": ["debug", "profiler", "release"] }
            }
        },
        "app": {
            "type": "object",
            "required": ["id", "frame", "time", "running", "canvas", "device"],
            "properties": {
                "id": { "type": "string" },
                "frame": { "type": "number" },
                "time": { "type": "number" },
                "running": { "type": "boolean" },
                "canvas": {
                    "type": "object",
                    "required": ["id", "width", "height"],
                    "properties": {
                        "id": { "type": ["string", "null"] },
                        "width": { "type": "number" },
                        "height": { "type": "number" }
                    }
                },
                "device": {
                    "type": "object",
                    "required": ["type", "maxTextureSize"],
                    "properties": {
                        "type": { "type": "string" },
                        "maxTextureSize": { "type": "number" }
                    }
                }
            }
        },
        "scene": {
            "type": "object",
            "required": ["entities", "cameras", "lights", "layers"],
            "properties": {
                "entities": { "type": "number" },
                "cameras": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["entity", "priority"],
                        "properties": {
                            "entity": { "type": "string" },
                            "priority": { "type": "number" }
                        }
                    }
                },
                "lights": { "type": "number" },
                "layers": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["id", "name", "enabled"],
                        "properties": {
                            "id": { "type": "number" },
                            "name": { "type": "string" },
                            "enabled": { "type": "boolean" }
                        }
                    }
                },
                "entitySample": { "type": "array" },
                "renderables": { "type": "array" },
                "collisions": { "type": "array" },
                "animations": { "type": "array" },
                "recentInput": { "type": "array" }
            }
        },
        "assets": {
            "type": "object",
            "required": ["counts", "failures"],
            "properties": {
                "counts": {
                    "type": "object",
                    "required": ["total", "loaded", "loading", "failed", "preloadPending"],
                    "properties": {
                        "total": { "type": "number" },
                        "loaded": { "type": "number" },
                        "loading": { "type": "number" },
                        "failed": { "type": "number" },
                        "preloadPending": { "type": "number" }
                    }
                },
                "failures": {
                    "type": "array",
                    "maxItems": 20,
                    "items": {
                        "type": "object",
                        "required": ["kind", "message", "assetId", "name", "url", "frame"],
                        "properties": {
                            "kind": { "const": "asset" },
                            "message": { "type": ["string", "null"] },
                            "assetId": { "type": ["number", "null"] },
                            "name": { "type": ["string", "null"] },
                            "url": { "type": ["string", "null"] },
                            "frame": { "type": ["number", "null"] }
                        }
                    }
                }
            }
        },
        "render": {
            "type": "object",
            "required": ["drawCalls", "triangles", "activeCamera"],
            "properties": {
                "drawCalls": { "type": "number" },
                "triangles": { "type": ["number", "null"] },
                "activeCamera": { "type": ["string", "null"] }
            }
        },
        "diagnostics": {
            "type": "object",
            "required": ["errors", "missingAssets"],
            "properties": {
                "errors": { "type": "number" },
                "missingAssets": { "type": "number" }
            }
        },
        "perf": {
            "type": "object",
            "required": ["fps", "frameMs", "cpuMs", "gpuMs"],
            "properties": {
                "fps": { "type": "number" },
                "frameMs": { "type": "number" },
                "cpuMs": { "type": ["number", "null"] },
                "gpuMs": { "type": ["number", "null"] }
            }
        }
    }
}
